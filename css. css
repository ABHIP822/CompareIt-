/* General Styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

body {
    background: #f4f6f8;
    height: 100vh;
}

/* Intro Screen */
#intro-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: linear-gradient(180deg, #1fa2ff, #12d8fa, #1dd1a1);
    color: white;
    z-index: 9999;
    text-align: center;
}

#intro-screen h1 {
    font-size: 42px;
    font-weight: bold;
    margin-bottom: 10px;
}

#intro-screen p {
    font-size: 18px;
    opacity: 0.9;
}

/* Login Screen */
#login-screen {
    padding: 20px;
    text-align: center;
}

.brand {
    color: #0097a7;
}

.subtitle {
    color: #777;
    margin-bottom: 20px;
}

.login-box {
    background: #f5f5f5;
    padding: 20px;
    border-radius: 15px;
    max-width: 350px;
    margin: auto;
    text-align: left;
}

.login-box label {
    font-weight: bold;
    display: block;
    margin-top: 10px;
}

.login-box input,
.login-box select {
    width: 100%;
    padding: 12px;
    margin-top: 5px;
    border-radius: 10px;
    border: 1px solid #ccc;
}

.login-box button {
    width: 100%;
    margin-top: 20px;
    padding: 14px;
    background: #0097a7;
    color: white;
    border: none;
    border-radius: 25px;
    font-size: 16px;
}

.toggle {
    margin-top: 15px;
    font-size: 14px;
}

.toggle a {
    color: #0097a7;
    text-decoration: none;
    font-weight: bold;
}

.toggle a:hover {
    text-decoration: underline;
}

/* Main App */
#main-app {
    padding: 20px;
}

header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #0097a7;
    color: white;
    padding: 15px 20px;
}

.logo {
    font-size: 22px;
    font-weight: bold;
}

.icons {
    font-size: 22px;
}

#settings-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: white;
}

#settings-menu {
    position: absolute;
    right: 20px;
    top: 60px;
    background: white;
    border: 1px solid #ddd;
    border-radius: 6px;
    width: 120px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

#settings-menu p {
    padding: 10px;
    cursor: pointer;
}

#settings-menu p:hover {
    background: #f1f1f1;
}

.hidden {
    display: none;
}

#search-input {
    width: 90%;
    margin: 20px auto;
    display: block;
    padding: 12px;
    border-radius: 8px;
    border: 1px solid #ccc;
}

#loading {
    text-align: center;
    margin: 20px;
    font-weight: bold;
}

#limit-message {
    text-align: center;
    color: red;
    font-weight: bold;
    margin-top: 20px;
}

.section-title {
    text-align: center;
    margin-top: 10px;
    color: #333;
}

#product-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    padding: 10px;
}

.product-card {
    width: 200px;
    background: white;
    margin: 10px;
    padding: 10px;
    border-radius: 10px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    cursor: pointer;
    transition: 0.2s;
}

.product-card:hover {
    transform: scale(1.05);
}

.product-card.selected {
    border: 2px solid #0097a7;
}

.product-card img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    border-radius: 8px;
}

